# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

IOS_DEPLOYMENT_TARGET = '15.1'

platform :ios, IOS_DEPLOYMENT_TARGET
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TechCalendarMobile' do
  config = use_native_modules!

  # Firebase Messaging ships Swift pods that need module maps when linked as static libraries.
  # Keep modular headers scoped to Firebase/Google pods to avoid changing every React Native pod.
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseMessaging', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'nanopb', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26 currently fails to compile fmt 11 with consteval format checks.
    # Keep the workaround in Podfile so it is re-applied after every pod install.
    fmt_base_header = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(fmt_base_header)
      fmt_base = File.read(fmt_base_header)
      patched_fmt_base = fmt_base.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0')
      if patched_fmt_base != fmt_base
        File.chmod(0o644, fmt_base_header)
        File.write(fmt_base_header, patched_fmt_base)
      end
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = IOS_DEPLOYMENT_TARGET
        # Keep app warnings visible, but do not let React Native/Pods internals flood Xcode.
        build_config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        build_config.build_settings['OTHER_LIBTOOLFLAGS'] = '$(inherited) -no_warning_for_no_symbols'
        build_config.build_settings['OTHER_SWIFT_FLAGS'] = '$(inherited) -Xcc -Wno-nullability-completeness -Xcc -Wno-deprecated-declarations'
        build_config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

        if target.name == 'Pods-TechCalendarMobile'
          build_config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'NO'
        end
      end
    end

    installer.pods_project.build_configurations.each do |build_config|
      build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = IOS_DEPLOYMENT_TARGET
    end

    # Keep this in Podfile instead of editing Pods.xcodeproj by hand:
    # CocoaPods regenerates the Hermes phase and Xcode warns unless it is explicitly always-run.
    hermes_target = installer.pods_project.targets.find { |target| target.name == 'hermes-engine' }
    hermes_target&.shell_script_build_phases&.each do |phase|
      next unless phase.name == '[CP-User] [Hermes] Replace Hermes for the right configuration, if needed'

      phase.always_out_of_date = '1'
    end
  end
end
